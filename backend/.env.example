PORT=5000
NODE_ENV=development

DATABASE_URL=postgres://username:password@hostname:5432/databasename?sslmode=require

JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

ADMIN_SECRET_KEY=super_secret_admin_registration_key

# --- Local Development ---
CLIENT_URL=http://localhost:3000

# --- Vercel Production Deployment ---
# In your Vercel Dashboard for the Backend project, configure:
# CLIENT_URL=https://your-frontend-app.vercel.app
# NODE_ENV=production
